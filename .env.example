# Copy this file to .env and fill in your real values.
# Never commit .env to git.

# Ollama — local AI, no API key needed
# The model must be pulled first: docker exec ollama ollama pull llama3.2
# Smaller fallback if RAM is tight: qwen2.5:0.5b or tinyllama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Jira
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# Kafka (default works with docker-compose as-is)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Django
DJANGO_SECRET_KEY=django-insecure-local-dev-only-change-in-production
